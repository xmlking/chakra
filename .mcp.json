{
  "mcpServers": {
    "better-auth": {
      "type": "http",
      "url": "https://mcp.better-auth.com/mcp"
    },
    "shadcn": {
      "command": "bunx",
      "args": ["shadcn@latest", "mcp"]
    },
    "mcp-docs-server": {
      "command": "bunx",
      "args": ["-y", "@assistant-ui/mcp-docs-server"]
    },
    "drizzle": {
      "command": "bunx",
      "args": ["drizzle-kit", "mcp"]
    },
    "reui": {
      "type": "http",
      "url": "https://mcp.reui.io",
      "headers": {
        "Authorization": "Bearer ${REUI_LICENSE_KEY}"
      }
    }
  }
}
