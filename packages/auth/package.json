{
  "name": "@workspace/auth",
  "version": "0.0.0",
  "private": true,
  "description": "Better-Auth module",
  "type": "module",
  "exports": {
    ".": "./src/index.tsx",
    "./*": "./src/*.ts",
    "./env": "./env.ts",
    "./studio.config": "./studio.config.ts"
  },
  "scripts": {
    "clean": "git clean -xdf vite-env.d.ts dist test-results coverage node_modules",
    "generate-schema": "bun x vite-node@latest scripts/generate-better-auth-schemas.ts",
    "generate-schema-ori": "dotenv-run -f ../../.env -v -- bun x auth@1.7.0-rc.0 generate --config src/index.tsx --output ../db/src/schema/copy_me_auth.ts -y",
    "postinstall": "vite-env types && vite-env generate",
    "studio": "dotenv-run -f ../../.env -v -- better-auth-studio start --port 3002 --config ./src/index.tsx",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@better-auth/api-key": "catalog:",
    "@better-auth/drizzle-adapter": "catalog:",
    "@better-auth/oauth-provider": "catalog:",
    "@better-auth/passkey": "catalog:",
    "@vite-env/core": "catalog:",
    "@workspace/db": "workspace:*",
    "@workspace/email": "workspace:*",
    "@workspace/shared": "workspace:*",
    "better-auth": "catalog:",
    "better-auth-studio": "catalog:",
    "react": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@vite-env/cli": "catalog:",
    "auth": "catalog:",
    "uuid": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "typescript": "catalog:"
  }
}
