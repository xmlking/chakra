{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "description": "Drizzle database module",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts",
    "./env": "./env.ts"
  },
  "scripts": {
    "check": "dotenv-run -f ../../.env -v -- drizzle-kit check --config=drizzle-tools.config.ts",
    "clean": "git clean -xdf vite-env.d.ts .drizzle dist test-results coverage node_modules",
    "export": "dotenv-run -f ../../.env -v -- drizzle-kit export --config=drizzle-tools.config.ts",
    "generate": "dotenv-run -f ../../.env -v -- drizzle-kit generate --config=drizzle-tools.config.ts",
    "mcp": "dotenv-run -f ../../.env -v -- drizzle-kit mcp --config=drizzle-tools.config.ts",
    "migrate": "dotenv-run -f ../../.env -v -- drizzle-kit migrate --config=drizzle-tools.config.ts",
    "postinstall": "vite-env types && vite-env generate",
    "pull": "dotenv-run -f ../../.env -v -- drizzle-kit pull --config=drizzle-tools.config.ts",
    "push": "dotenv-run -f ../../.env -v -- drizzle-kit push --config=drizzle-tools.config.ts",
    "seed": "bun x vite-node@latest scripts/seed.ts",
    "skills": "dotenv-run -f ../../.env -v -- drizzle-kit skills --config=drizzle-tools.config.ts",
    "studio": "dotenv-run -f ../../.env -v -- drizzle-kit studio --config=drizzle-tools.config.ts",
    "typecheck": "tsgo --noEmit",
    "up": "dotenv-run -f ../../.env -v -- drizzle-kit up --config=drizzle-tools.config.ts"
  },
  "dependencies": {
    "@vite-env/core": "catalog:",
    "@workspace/shared": "workspace:*",
    "better-result": "catalog:",
    "drizzle-orm": "catalog:",
    "pg": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@better-auth/utils": "0.4.2",
    "@noble/hashes": "2.2.0",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "@vite-env/cli": "catalog:",
    "drizzle-kit": "catalog:",
    "drizzle-seed": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@typescript/native-preview": "catalog:",
    "typescript": "catalog:"
  }
}
