{
  "name": "@workspace/shared",
  "version": "1.0.0",
  "private": true,
  "description": "Shared utilities for workspace packages",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "check": "vp check",
    "clean": "git clean -xdf dist node_modules",
    "dev": "vp pack --watch",
    "prepublishOnly": "vp run build",
    "test": "vp test",
    "typecheck": "tsgo --noEmit"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "bumpp": "^11.1.0",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  }
}
