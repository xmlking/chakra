{
  "name": "@workspace/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Shared UI components for workspace applications",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "imports": {
    "#components/*": "./src/components/*.tsx",
    "#hooks/*": "./src/hooks/*.ts",
    "#lib/*": "./src/lib/*.ts"
  },
  "exports": {
    "./blocks/*": "./src/blocks/*.tsx",
    "./components/*": "./src/components/*.tsx",
    "./globals.css": "./src/styles/globals.css",
    "./hooks/*": "./src/hooks/*.ts",
    "./lib/*": "./src/lib/*.ts",
    "./styles/*": "./src/styles/*",
    "./templates/*": "./src/templates/*"
  },
  "scripts": {
    "clean": "git clean -xdf dist test-results coverage node_modules",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/noto-sans": "5.2.10",
    "@fontsource-variable/playfair-display": "5.2.8",
    "@icons-pack/react-simple-icons": "catalog:",
    "class-variance-authority": "0.7.1",
    "clsx": "catalog:",
    "cmdk": "^1.1.1",
    "date-fns": "catalog:",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "catalog:",
    "next-themes": "^0.4.6",
    "react-day-picker": "^10.0.1",
    "react-resizable-panels": "4.11.2",
    "recharts": "3.8.1",
    "shadcn": "4.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0",
    "vaul": "^1.1.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/eslint-config": "0.4.0",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  }
}
