{
  "name": "@workspace/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Shared UI components for workspace applications",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "imports": {
    "#components/*": "./src/components/*.tsx",
    "#hooks/*": "./src/hooks/*.ts",
    "#lib/*": "./src/lib/*.ts",
    "#lib/auth/organization-plugin": "./src/lib/auth/organization-plugin.tsx",
    "#types/*": "./src/types/*.ts"
  },
  "exports": {
    "./blocks/*": "./src/blocks/*.tsx",
    "./components/*": "./src/components/*.tsx",
    "./globals.css": "./src/styles/globals.css",
    "./hooks/*": "./src/hooks/*.ts",
    "./lib/*": "./src/lib/*.ts",
    "./lib/auth/organization-plugin": "./src/lib/auth/organization-plugin.tsx",
    "./styles/*": "./src/styles/*"
  },
  "scripts": {
    "clean": "git clean -xdf dist test-results coverage node_modules",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "catalog:",
    "@better-auth-ui/core": "catalog:",
