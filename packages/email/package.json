{
  "name": "@workspace/email",
  "version": "0.0.0",
  "private": true,
  "description": "Email templates",
  "type": "module",
  "imports": {
    "#components/*": "./src/components/*.tsx",
    "#hooks/*": "./src/hooks/*.ts",
    "#lib/*": "./src/lib/*.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./*": "./emails/*.tsx",
    "./env": "./env.ts"
  },
  "scripts": {
    "build": "email build",
    "clean": "git clean -xdf vite-env.d.ts .react-email dist out node_modules",
    "cli": "bunx email-sdk",
    "dev": "email dev --port 3010",
    "export": "email export",
    "postinstall": "vite-env types && vite-env generate"
  },
  "dependencies": {
    "@opencoredev/email-sdk": "catalog:",
    "@vite-env/core": "catalog:",
    "@workspace/ui": "workspace:*",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-email": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@react-email/ui": "catalog:",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vite-env/cli": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "typescript": "catalog:"
  }
}
