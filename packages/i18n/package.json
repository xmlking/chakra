{
  "name": "@workspace/i18n",
  "version": "0.0.0",
  "private": true,
  "description": "Shared i18n messages",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./messages": "./src/paraglide/messages.js",
    "./runtime": "./src/paraglide/runtime.js",
    "./server": "./src/paraglide/server.js"
  },
  "scripts": {
    "build": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide --emit-ts-declarations",
    "dev": "paraglide-js compile --watch --project ./project.inlang --outdir ./src/paraglide --emit-ts-declarations",
    "translate": "inlang machine translate --project ./project.inlang",
    "validate": "inlang validate --project ./project.inlang"
  },
  "devDependencies": {
    "@inlang/cli": "catalog:",
    "@inlang/paraglide-js": "catalog:",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "bumpp": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "@typescript/native-preview": "catalog:",
    "typescript": "catalog:"
  }
}
