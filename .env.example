# Auto-generated by @vite-env/cli — do not edit manually
# Run: npx vite-env generate

# ── Client variables (VITE_ prefix — available everywhere)
# VITE_APP_NAME: string — required
VITE_APP_NAME=

# VITE_CONSOLE_URL: string — required
VITE_CONSOLE_URL=

# VITE_DOCS_URL: string — required
VITE_DOCS_URL=

# VITE_WEB_URL: string — required
VITE_WEB_URL=

# VITE_DEBUG: boolean (true | false | 1 | 0)
VITE_DEBUG=false

# ── Server-only variables (never sent to browser)
# DATABASE_URL: string — required
DATABASE_URL=

# DB_POOL_SIZE: number
DB_POOL_SIZE=10

# BETTER_AUTH_ADMINS: string — required
BETTER_AUTH_ADMINS=

# BETTER_AUTH_ADMIN_EMAIL: string — required
BETTER_AUTH_ADMIN_EMAIL=

# BETTER_AUTH_ADMIN_PASSWORD: string — required
BETTER_AUTH_ADMIN_PASSWORD=

# SHARED_ORGANIZATION_ID: string — required
SHARED_ORGANIZATION_ID=

# CONTACT_EMAIL: string — required
CONTACT_EMAIL=

# OPENROUTER_API_KEY: string — required
OPENROUTER_API_KEY=

# OPENROUTER_MODEL: string — required
OPENROUTER_MODEL=

# Resend server config - required only if you use Resend as an email provider
RESEND_API_KEY="<your-resend-api-key>"

# SMTP server config
SMTP_HOST="smtp.resend.com"
# 587 (465 if secure: true)
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="resend"
SMTP_PASS="${RESEND_API_KEY}"

# Auto-generated by @vite-env/cli — do not edit manually
# Run: npx vite-env generate

# ── Server-only variables (never sent to browser)
# S3_IMAGES_BUCKET: string — required
S3_IMAGES_BUCKET=images

# S3_AGENTS_BUCKET: string — required
S3_AGENTS_BUCKET=agents

# S3_REGION: string
S3_REGION=us-east-1

# S3_ENDPOINT: string — required
S3_ENDPOINT=http://localhost:9000

# S3_ACCESS_KEY_ID: string — required
S3_ACCESS_KEY_ID=

# S3_SECRET_ACCESS_KEY: string — required
S3_SECRET_ACCESS_KEY=
