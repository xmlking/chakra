{
  "name": "docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "dotenv-run -f ../../.env -v -- waku build",
    "clean": "git clean -xdf vite-env.d.ts .output .tanstack .source dist test-results coverage node_modules",
    "dev": "dotenv-run -f ../../.env -v -- waku dev --port=3001",
    "postinstall": "vite-env types && vite-env generate && fumadocs-mdx",
    "start": "dotenv-run -f ../../.env -v -- waku start",
    "types:check": "fumadocs-mdx && tsc --noEmit"
  },
