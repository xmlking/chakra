{
  "name": "docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#features/*": "./src/features/*",
    "#components/*": "./src/components/*.tsx",
    "#config/*": "./src/config/*.ts",
    "#hooks/*": "./src/hooks/*.ts",
    "#lib/*": "./src/lib/*.ts",
    "#types/*": "./src/types/*.ts"
  },
  "scripts": {
    "build": "waku build",
    "clean": "git clean -xdf .output .tanstack .source test-results coverage node_modules",
    "dev": "waku dev",
    "postinstall": "vite-env types && vite-env generate && fumadocs-mdx",
    "preview": "waku preview",
    "start": "waku start",
    "types:check": "fumadocs-mdx && tsc --noEmit"
  },
  "dependencies": {
    "@fumapress/feedback": "0.5.1",
    "@lonik/themer": "^0.5.4",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tabs": "1.1.13",
    "@vite-env/core": "catalog:",
    "@workspace/i18n": "workspace:*",
    "@workspace/shared": "workspace:*",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "fumadocs-core": "16.9.3",
    "fumadocs-mdx": "15.0.10",
    "fumadocs-openapi": "10.9.1",
    "fumadocs-ui": "16.9.3",
    "fumapress": "0.5.1",
    "lucide-react": "catalog:",
    "mermaid": "11.15.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-server-dom-webpack": "19.2.6",
    "shiki": "4.1.0",
    "tailwind-merge": "catalog:",
    "waku": "1.0.0-beta.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:",
    "@types/bun": "catalog:",
    "@types/mdx": "2.0.13",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vite-env/cli": "catalog:",
    "tailwindcss": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "@typescript/native-preview": "catalog:",
    "shiki": "catalog:",
    "typescript": "catalog:"
  }
}
