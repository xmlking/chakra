{
  "name": "web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#components/*": "./src/components/*.tsx",
    "#config/*": "./src/config/*.ts",
    "#hooks/*": "./src/hooks/*.ts",
    "#lib/*": "./src/lib/*.ts",
    "#paraglide/*": "./src/paraglide/*.js",
    "#types/*": "./src/types/*.ts"
  },
  "scripts": {
    "build": "tsc && vp build && cp instrument.server.mjs .output/server",
    "clean": "git clean -xdf .output .tanstack test-results node_modules",
    "dev": "NODE_OPTIONS='--import ./instrument.server.mjs' vp dev",
    "preview": "vp preview",
    "start": "node --import ./.output/server/instrument.server.mjs .output/server/index.mjs",
    "test": "playwright test",
    "test:debug": "playwright test --debug",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "test:ui": "playwright test --ui"
  },
  "dependencies": {
    "@inlang/paraglide-js": "catalog:",
    "@lonik/themer": "catalog:",
    "@sentry/tanstackstart-react": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@tanstack/match-sorter-utils": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-query-devtools": "catalog:",
    "@tanstack/react-router": "catalog:",
    "@tanstack/react-router-devtools": "catalog:",
    "@tanstack/react-router-ssr-query": "catalog:",
    "@tanstack/react-start": "catalog:",
    "@tanstack/react-store": "catalog:",
    "@tanstack/router-plugin": "catalog:",
    "@workspace/ui": "workspace:*",
    "better-auth": "catalog:",
    "lucide-react": "catalog:",
    "nitro": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwindcss": "catalog:",
    "vite-tsconfig-paths": "6.1.1"
  },
  "devDependencies": {
    "@playwright/test": "catalog:",
    "@tanstack/devtools-vite": "catalog:",
    "@tanstack/eslint-config": "0.4.0",
    "@tanstack/react-devtools": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  }
}
